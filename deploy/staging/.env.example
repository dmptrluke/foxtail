# Foxtail staging environment configuration.
# Copy this file to .env and fill in the values.

# =============================================================================
# Required settings
# =============================================================================

# Compose project name (namespaces containers and volumes)
COMPOSE_PROJECT_NAME=staging

# Django secret key (see README for generation instructions)
SECRET_KEY=

# Previous secret keys (comma-separated) for graceful rotation.
# Sessions/tokens signed with old keys remain valid until they expire.
# SECRET_KEY_FALLBACKS=old-key-1,old-key-2

# Public URL of the site (no trailing slash)
SITE_URL=https://example.com

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=example.com

# Comma-separated list of email addresses to receive contact form submissions
CONTACT_EMAILS=admin@example.com

# =============================================================================
# ReCAPTCHA
# =============================================================================

# Set to false to use checkbox reCAPTCHA instead of invisible (defaults to true)
# RECAPTCHA_INVISIBLE=true

# reCAPTCHA keys
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# =============================================================================
# Social Login
# =============================================================================

# GitHub OIDC (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OIDC (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Discord OIDC (optional)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Telegram OIDC (optional)
# TELEGRAM_CLIENT_ID=
# TELEGRAM_CLIENT_SECRET=

# =============================================================================
# OIDC Identity Provider
# =============================================================================

# RSA private key for signing OIDC tokens (PEM format, all on one line with \n)
# OIDC_RSA_PRIVATE_KEY=


# =============================================================================
# Email (pick one)
# =============================================================================

# Option 1: Mailgun
# MAILGUN_API_KEY=
# MAILGUN_SENDER_DOMAIN=

# Option 2: SMTP
# EMAIL_URL=smtp://user:password@smtp.example.com:587

# Sender addresses
EMAIL_FROM_USER=noreply@example.com
EMAIL_FROM_SYSTEM=server@example.com

# =============================================================================
# S3-compatible storage for media (optional - uses local filesystem if not set)
# =============================================================================

# S3_MEDIA=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=mybucket
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_DOMAIN=cdn.example.com

# If using S3 storage, set ASSET_HOSTS to your public bucket/CDN domain so
# that CSP headers allow loading images, fonts, styles, and scripts from it.
# ASSET_HOSTS=https://cdn.example.com

# =============================================================================
# Sentry error tracking (optional)
# =============================================================================

# SENTRY_DSN=
# SENTRY_PII=false
# SENTRY_CSP=false

# Tag events with an environment name (e.g. production, staging)
SENTRY_ENVIRONMENT=staging

# =============================================================================
# Misc
# =============================================================================

# Set to true if behind a reverse proxy that sets X-Forwarded-Host
USE_X_FORWARDED_HOST=true

# CSP violation report endpoint (auto-set if SENTRY_CSP is enabled)
# CSP_REPORT_URI=


# Allow search engine crawling
# ROBOTS_ALLOWED=true

# MapTiler API key (optional - enables geocoding + interactive maps on events)
# MAPTILER_API_KEY=

# Default color scheme for new visitors (before they set a preference).
# Valid values: plum, coffee, autumn, forest, slate. Defaults to plum.
DEFAULT_COLOR_SCHEME=coffee
