# Add a site block for each app stack.
# The reverse_proxy target uses a network alias defined in each stack's compose.yaml.

# Production
furry.nz {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-XSS-Protection "0"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), midi=(), accelerometer=(), gyroscope=(), magnetometer=(), autoplay=(), fullscreen=(self), interest-cohort=()"
	}
	encode zstd gzip
	handle /webhook/* {
		reverse_proxy prod-bot:8001
	}
	handle {
		reverse_proxy prod-app:8000
	}
}

# Staging
test.furry.nz {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-XSS-Protection "0"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), midi=(), accelerometer=(), gyroscope=(), magnetometer=(), autoplay=(), fullscreen=(self), interest-cohort=()"
	}
	encode zstd gzip
	handle /webhook/* {
		reverse_proxy staging-bot:8001
	}
	handle {
		reverse_proxy staging-app:8000
	}
}
