{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Infra: Start",
            "type": "shell",
            "command": "docker compose up -d",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Infra: Stop",
            "type": "shell",
            "command": "docker compose down",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Dev Server",
            "type": "shell",
            "command": "uv run python src/manage.py runserver",
            "isBackground": true,
            "dependsOn": "Infra: Start",
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "owner": "django",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Watching for file changes",
                    "endsPattern": "Quit the server with"
                }
            }
        },
        {
            "label": "Vite: Dev Server",
            "type": "shell",
            "command": "npm run dev",
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "ready in"
                }
            }
        },
        {
            "label": "Dev: Start All",
            "dependsOn": ["Django: Dev Server", "Vite: Dev Server"],
            "dependsOrder": "parallel",
            "runOptions": {
                "instanceLimit": 1
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Run Migrations",
            "type": "shell",
            "command": "uv run python src/manage.py migrate",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Open Shell",
            "type": "shell",
            "command": "uv run python src/manage.py shell",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Create Superuser",
            "type": "shell",
            "command": "uv run python src/manage.py createsuperuser --username ${input:superuserUsername} --email ${input:superuserEmail}",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Warm Images",
            "type": "shell",
            "command": "uv run python src/manage.py warm_images",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Generate Sample Data",
            "type": "shell",
            "command": "uv run python src/manage.py generate_sample_data --users ${input:sampleUsers} --posts ${input:samplePosts} --comments ${input:sampleComments} --events ${input:sampleEvents} --pages ${input:samplePages}",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Postgres: Wipe Database",
            "type": "shell",
            "command": "docker compose exec -T db psql -U foxtail foxtail -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;'",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Postgres: Load Dump",
            "type": "shell",
            "command": "cat ${input:dumpFile} | docker compose exec -T db psql -U foxtail foxtail",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Test: Run",
            "type": "shell",
            "command": "uv run pytest src/apps/ -v",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Start Prod Server",
            "type": "shell",
            "command": "docker compose -f compose.yaml -f compose.prod.yaml down && docker compose -f compose.yaml -f compose.prod.yaml up --build foxtail",
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "owner": "docker-gunicorn",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Attaching to",
                    "endsPattern": "\\[INFO\\] Listening at"
                }
            }
        }
    ],
    "inputs": [
        {
            "id": "superuserUsername",
            "type": "promptString",
            "description": "Superuser username"
        },
        {
            "id": "superuserEmail",
            "type": "promptString",
            "description": "Superuser email address",
            "default": ""
        },
        {
            "id": "dumpFile",
            "type": "promptString",
            "description": "Path to the .sql dump file to load"
        },
        {
            "id": "sampleUsers",
            "type": "promptString",
            "description": "Number of users to create",
            "default": "10"
        },
        {
            "id": "samplePosts",
            "type": "promptString",
            "description": "Number of blog posts to create",
            "default": "20"
        },
        {
            "id": "sampleComments",
            "type": "promptString",
            "description": "Number of blog comments to create",
            "default": "30"
        },
        {
            "id": "sampleEvents",
            "type": "promptString",
            "description": "Number of events to create",
            "default": "10"
        },
        {
            "id": "samplePages",
            "type": "promptString",
            "description": "Number of content pages to create",
            "default": "5"
        }
    ]
}
