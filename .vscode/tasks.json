{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Docker: Build Dev",
            "type": "shell",
            "command": "docker compose build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Stop All",
            "type": "shell",
            "command": "docker compose down",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Run Migrations",
            "type": "shell",
            "command": "docker compose run --rm foxtail django-admin migrate",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Open Shell",
            "type": "shell",
            "command": "docker compose run --rm foxtail bash",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Start Dev Server",
            "type": "shell",
            "command": "docker compose down && docker compose up --build foxtail",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "owner": "docker-debugpy",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Attaching to",
                    "endsPattern": "Listening for debugger connections"
                }
            }
        },
        {
            "label": "Docker: Build Tests",
            "type": "shell",
            "command": "docker compose -f compose.yaml -f compose.test.yaml build test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Create Superuser",
            "type": "shell",
            "command": "docker compose run --rm -e DJANGO_SUPERUSER_PASSWORD=${input:superuserPassword} foxtail django-admin createsuperuser --username ${input:superuserUsername} --email ${input:superuserEmail} --no-input",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Postgres: Wipe Database",
            "type": "shell",
            "command": "docker compose exec -T db psql -U foxtail foxtail -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;'",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Postgres: Load Dump",
            "type": "shell",
            "command": "cat ${input:dumpFile} | docker compose exec -T db psql -U foxtail foxtail",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Django: Generate Sample Data",
            "type": "shell",
            "command": "docker compose run --rm foxtail django-admin generate_sample_data --users ${input:sampleUsers} --posts ${input:samplePosts} --comments ${input:sampleComments} --events ${input:sampleEvents} --pages ${input:samplePages}",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "superuserUsername",
            "type": "promptString",
            "description": "Superuser username"
        },
        {
            "id": "superuserEmail",
            "type": "promptString",
            "description": "Superuser email address",
            "default": ""
        },
        {
            "id": "superuserPassword",
            "type": "promptString",
            "description": "Superuser password",
            "password": true
        },
        {
            "id": "dumpFile",
            "type": "promptString",
            "description": "Path to the .sql dump file to load"
        },
        {
            "id": "sampleUsers",
            "type": "promptString",
            "description": "Number of users to create",
            "default": "10"
        },
        {
            "id": "samplePosts",
            "type": "promptString",
            "description": "Number of blog posts to create",
            "default": "20"
        },
        {
            "id": "sampleComments",
            "type": "promptString",
            "description": "Number of blog comments to create",
            "default": "30"
        },
        {
            "id": "sampleEvents",
            "type": "promptString",
            "description": "Number of events to create",
            "default": "10"
        },
        {
            "id": "samplePages",
            "type": "promptString",
            "description": "Number of content pages to create",
            "default": "5"
        }
    ]
}
